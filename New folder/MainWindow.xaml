<Window x:Class="StudentManagementSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student Management System" Height="350" Width="400">

    <Grid>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="Student Management System"
                       FontSize="22"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

            <Button Content="Add Student"
                    Width="150"
                    Height="40"
                    Margin="0,10"
                    Click="AddStudent_Click"/>

            <Button Content="View Students"
                    Width="150"
                    Height="40"
                    Margin="0,10"
                    Click="ViewStudents_Click"/>
                    

        </StackPanel>

    </Grid>

</Window>