<Window x:Class="StudentManagementSystem.AddStudent"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Student" Height="350" Width="350"
        Background="White">

    <Grid Background="White">
        <StackPanel Margin="20">

            <TextBlock Text="Add Student" FontSize="20" Margin="0,0,0,20"/>

            <TextBlock Text="Name"/>
            <TextBox Name="txtName" Height="30" Margin="0,5"/>

            <TextBlock Text="Age"/>
            <TextBox Name="txtAge" Height="30" Margin="0,5"/>

            <TextBlock Text="Course"/>
            <TextBox Name="txtCourse" Height="30" Margin="0,5"/>

            <Button Content="Save Student"
                    Height="35"
                    Margin="0,15,0,0"
                    Click="SaveStudent_Click"/>

        </StackPanel>
    </Grid>

</Window>